# Copy to .env.watchtower and edit values.

# Image to deploy and auto-update
APP_IMAGE=ghcr.io/your-username/your-project:latest
APP_PORT=3000

# GHCR credentials for private repos (PAT needs read:packages)
GH_USERNAME=your-github-username
GH_PAT_TOKEN=your-ghcr-read-token

# Watchtower behavior
WATCHTOWER_POLL_INTERVAL=30

# Notification settings
# For Discord/Slack via Shoutrrr, set WATCHTOWER_NOTIFICATION_URL.
# Example Discord URL format:
# WATCHTOWER_NOTIFICATION_URL=discord://webhook-id/webhook-token
WATCHTOWER_NOTIFICATIONS=shoutrrr
WATCHTOWER_NOTIFICATION_URL=
