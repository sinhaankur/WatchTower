NODE_NAME=standby
NODE_TAILSCALE_IP=100.64.10.11
PEER_TAILSCALE_IP=100.64.10.10

# Public routing
APP_DOMAIN=app.example.com
PREVIEW_BASE_DOMAIN=preview.example.com
ACME_EMAIL=ops@example.com

# Deployed image and ports
APP_IMAGE=ghcr.io/your-org/your-app:latest
APP_CONTAINER_PORT=8000
APP_BLUE_PORT=18080
APP_GREEN_PORT=18081
PREVIEW_PORT_BASE=19000
HEALTHCHECK_PATH=/health
HEALTHCHECK_TIMEOUT_SECONDS=90
CUTOVER_GRACE_SECONDS=5

# Node environment
NODE_ENV=production
CADDY_ADMIN_PORT=2019

# GHCR credentials for private images
GH_USERNAME=your-github-username
GH_PAT_TOKEN=your-ghcr-read-token

# Podman secrets
MESH_MONGO_SECRET_NAME=mongo_uri
MONGODB_URI_FILE=/run/secrets/mongo_uri
MESH_DATABASE_URL_SECRET_NAME=
DATABASE_URL_FILE=

# Optional app env passthrough
WATCHTOWER_API_TOKEN=
WATCHTOWER_SECRET_KEY=
ATLAS_APP_NAME=watchtower-mesh-standby
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2
MONGO_MAX_IDLE_TIME_MS=300000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=30000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Watchtower sync interval for mesh infrastructure
WATCHTOWER_POLL_INTERVAL=15
WATCHTOWER_NOTIFICATIONS=shoutrrr
WATCHTOWER_NOTIFICATION_URL=