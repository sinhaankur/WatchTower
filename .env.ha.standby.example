NODE_NAME=standby
NODE_TAILSCALE_IP=100.64.10.11
PEER_TAILSCALE_IP=100.64.10.10

# Container image for the application
APP_IMAGE=ghcr.io/your-org/your-app:latest
APP_PORT=8080

# GHCR credentials for private images (PAT requires read:packages)
GH_USERNAME=your-github-username
GH_PAT_TOKEN=your-ghcr-read-token

# DB credentials
POSTGRESQL_POSTGRES_PASSWORD=change-me-superuser
POSTGRESQL_USERNAME=watchtower
POSTGRESQL_PASSWORD=change-me-app-user
POSTGRESQL_DATABASE=watchtower

# Replication settings (standby)
POSTGRESQL_REPLICATION_MODE=slave
POSTGRESQL_REPLICATION_USER=repl_user
POSTGRESQL_REPLICATION_PASSWORD=change-me-repl-user
POSTGRESQL_MASTER_HOST=100.64.10.10
POSTGRESQL_MASTER_PORT_NUMBER=5432

# Watchtower settings
WATCHTOWER_POLL_INTERVAL=60
WATCHTOWER_NOTIFICATIONS=shoutrrr
WATCHTOWER_NOTIFICATION_URL=

# Optional backend auth hardening
WATCHTOWER_API_TOKEN=
WATCHTOWER_SECRET_KEY=
