{
  "name": "watchtower-podman",
  "displayName": "WatchTower Ops",
  "description": "Deploy, monitor, and manage WatchTower projects from VS Code — sidebar tree, one-click deploy, live build logs, and rollback. Talks to any WatchTower API server (local desktop app, PyPI install, Docker, or self-hosted).",
  "version": "1.5.18",
  "publisher": "sinhaankur",
  "license": "MIT",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "watchtower",
    "deploy",
    "docker",
    "podman",
    "devops"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sinhaankur/WatchTower"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "configuration": {
      "title": "WatchTower",
      "properties": {
        "watchtower.apiUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "Base URL of your WatchTower API server"
        },
        "watchtower.apiToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "API token for authentication. You can also store this in your system keychain by running the **WatchTower: Set API Token** command.",
          "scope": "machine"
        },
        "watchtower.pollIntervalSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "description": "How often (in seconds) to refresh project and service status"
        },
        "watchtower.openBrowserOnDeploy": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the web UI after triggering a deployment"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "watchtower-sidebar",
          "title": "WatchTower",
          "icon": "assets/wt-sidebar.svg"
        }
      ]
    },
    "views": {
      "watchtower-sidebar": [
        {
          "id": "watchtower.projectsView",
          "name": "Projects",
          "icon": "assets/wt-sidebar.svg",
          "contextualTitle": "WatchTower Projects"
        },
        {
          "id": "watchtower.servicesView",
          "name": "Services & Integrations",
          "icon": "assets/wt-sidebar.svg",
          "contextualTitle": "WatchTower Services"
        }
      ]
    },
    "commands": [
      {
        "command": "watchtower.refresh",
        "title": "WatchTower: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "watchtower.setApiToken",
        "title": "WatchTower: Set API Token"
      },
      {
        "command": "watchtower.openWebUi",
        "title": "WatchTower: Open Web UI",
        "icon": "$(globe)"
      },
      {
        "command": "watchtower.deployProject",
        "title": "WatchTower: Deploy Project",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "watchtower.openProjectLogs",
        "title": "WatchTower: Show Deployment Logs",
        "icon": "$(output)"
      },
      {
        "command": "watchtower.openProjectInBrowser",
        "title": "WatchTower: Open Project URL",
        "icon": "$(link-external)"
      },
      {
        "command": "watchtower.copyProjectId",
        "title": "WatchTower: Copy Project ID"
      },
      {
        "command": "watchtower.rollbackDeployment",
        "title": "WatchTower: Rollback Last Deployment",
        "icon": "$(history)"
      },
      {
        "command": "watchtower.openInVscode",
        "title": "WatchTower: Open Project Folder in VS Code",
        "icon": "$(folder-opened)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "watchtower.refresh",
          "when": "view == watchtower.projectsView || view == watchtower.servicesView",
          "group": "navigation"
        },
        {
          "command": "watchtower.openWebUi",
          "when": "view == watchtower.projectsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "watchtower.deployProject",
          "when": "viewItem == watchtowerProject",
          "group": "inline@1"
        },
        {
          "command": "watchtower.openProjectLogs",
          "when": "viewItem == watchtowerProject",
          "group": "inline@2"
        },
        {
          "command": "watchtower.openInVscode",
          "when": "viewItem == watchtowerProject",
          "group": "inline@3"
        },
        {
          "command": "watchtower.deployProject",
          "when": "viewItem == watchtowerProject",
          "group": "1_actions@1"
        },
        {
          "command": "watchtower.rollbackDeployment",
          "when": "viewItem == watchtowerProject",
          "group": "1_actions@2"
        },
        {
          "command": "watchtower.openProjectInBrowser",
          "when": "viewItem == watchtowerProject",
          "group": "1_actions@3"
        },
        {
          "command": "watchtower.openProjectLogs",
          "when": "viewItem == watchtowerProject",
          "group": "1_actions@4"
        },
        {
          "command": "watchtower.copyProjectId",
          "when": "viewItem == watchtowerProject",
          "group": "2_copy@1"
        }
      ],
      "explorer/context": [
        {
          "command": "watchtower.deployProject",
          "group": "watchtower@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package:bundle",
    "typecheck": "tsc --noEmit -p ./",
    "bundle": "node esbuild.config.cjs",
    "bundle:watch": "node esbuild.config.cjs --watch",
    "compile": "npm run typecheck && npm run bundle",
    "watch": "npm run bundle:watch",
    "package:bundle": "npm run typecheck && node esbuild.config.cjs --production",
    "lint": "eslint src --ext ts",
    "package": "npm run package:bundle && vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0"
  }
}
